# EditorConfig helps developers define and maintain consistent coding styles between different editors and IDEs.
# http://editorconfig.org

root = true

# Global settings for all files
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# Python files (standard 4 spaces)
[*.py]
indent_style = space
indent_size = 4

# JavaScript, TypeScript, React, and JSON files (standard 2 spaces)
[*.{js,jsx,ts,tsx,json}]
indent_style = space
indent_size = 2

# Web styling and markup files (2 spaces)
[*.{html,css,scss}]
indent_style = space
indent_size = 2

# YAML configuration files (2 spaces)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files (disable trim_trailing_whitespace to preserve markdown double-space line breaks)
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
